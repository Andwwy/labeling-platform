# Copy to .env and fill in. .env is gitignored; .env.example is the shared
# template. labeling-platform.html fetches '.env' on boot and parses these
# values into window.__LABELING_CONFIG.
#
# Get a MotherDuck token at https://app.motherduck.com/settings/tokens
MOTHERDUCK_TOKEN=
MOTHERDUCK_DATABASE=rules_in_the_wild
